# AlayaOS Configuration
# Copy to .env and modify as needed

# Database
ALAYA_DATABASE_URL=postgresql+asyncpg://alaya:alaya@localhost:5432/alaya

# Redis
ALAYA_REDIS_URL=redis://localhost:6379/0

# Environment: dev | production
ALAYA_ENV=dev

# Secret key for session signing (change in production!)
ALAYA_SECRET_KEY=change-me-in-production
